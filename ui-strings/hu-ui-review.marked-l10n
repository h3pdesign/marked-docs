# EN: List the five to eight most important points from the document as a Markdown bullet list.

"Markdown" = "Markdown";

"No document text to analyze." = "Nincs elemezni kívánt dokumentumszöveg.";
# EN: No document text to analyze.

"Outline" = "Vázlat";
# EN: Outline

"Outlining" = "Körvonalazás";
# EN: Outlining

"Preparing" = "Felkészülés";
# EN: Preparing

