# EN: Section %ld: %@

"Section summaries:

%@" = "A szakaszok összefoglalói:

%@";
# EN: Section summaries:\n\n%@

"Select text in the preview first, or use Summarize Document." = "Először válassza ki a szöveget az előnézetben, vagy használja a Dokumentum összegzése funkciót.";
# EN: Select text in the preview first, or use Summarize Document.

"Select text in the preview first." = "Először válassza ki a szöveget az előnézetben.";
# EN: Select text in the preview first.

"Starting…" = "Indítás…";
# EN: Starting…

"Summaries and answers appear here, just above your question." = "Az összefoglalók és a válaszok itt, közvetlenül a kérdése felett jelennek meg.";
# EN: Summaries and answers appear here, just above your question.

"Summarize Document" = "Összefoglaló dokumentum";
# EN: Summarize Document

"Summarize Selection" = "A kiválasztás összefoglalása";
# EN: Summarize Selection

"Summarize the following excerpt in three to five sentences." = "Foglalja össze három-öt mondatban a következő részletet!";
# EN: Summarize the following excerpt in three to five sentences.

"Summarize this section in two or three sentences." = "Foglalja össze ezt a részt két vagy három mondatban.";
# EN: Summarize this section in two or three sentences.

"Summarizing" = "Összegzés";
# EN: Summarizing

"Summarizing document…" = "Összefoglaló dokumentum…";
# EN: Summarizing document…

"Summarizing selection…" = "Kiválasztás összegzése…";
# EN: Summarizing selection…

"Thinking…" = "Gondolkodás…";
# EN: Thinking…

"This Mac does not support Apple Intelligence." = "Ez a Mac nem támogatja a Apple Intelligence kifejezést.";
# EN: This Mac does not support Apple Intelligence.

"This document has no text to analyze." = "Ebben a dokumentumban nincs elemeznivaló szöveg.";
# EN: This document has no text to analyze.

"This document is too large for a single request. Try selecting a smaller passage or ask a narrower question." = "Ez a dokumentum túl nagy egyetlen kérelemhez. Próbáljon meg egy kisebb részt kiválasztani, vagy tegyen fel egy szűkebb kérdést.";
# EN: This document is too large for a single request. Try selecting a smaller passage or ask a narrower question.

"Turn on Apple Intelligence in System Settings to use Ask About Document." = "A Kérdezzen a dokumentumról funkció használatához kapcsolja be a Apple Intelligence funkciót a Rendszerbeállításokban.";
# EN: Turn on Apple Intelligence in System Settings to use Ask About Document.

"Turn on Apple Intelligence in System Settings to use this feature." = "A funkció használatához kapcsolja be a Apple Intelligence kifejezést a Rendszerbeállításokban.";
# EN: Turn on Apple Intelligence in System Settings to use this feature.

"Uses on-device Apple Intelligence." = "Az eszközön használja a Apple Intelligence.";
# EN: Uses on-device Apple Intelligence.

"What's on your mind?" = "Mi jár a fejedben?";
# EN: What's on your mind?

"Write a cohesive summary of the full document in four to eight sentences." = "Írja le a teljes dokumentum összefoglalóját négy-nyolc mondatban.";
# EN: Write a cohesive summary of the full document in four to eight sentences.

"You help someone review a document open in Marked, a Markdown preview app.
Use only the document text provided in the prompt. Be accurate and concise.
If the text does not contain enough information, say so briefly.
Write all responses in %@." = "Segít másoknak áttekinteni a Marked, a Markdown előnézeti alkalmazásban megnyitott dokumentumot.
Csak a promptban megadott dokumentumszöveget használja. Legyen pontos és tömör.
Ha a szöveg nem tartalmaz elegendő információt, mondja el röviden.
Írja be az összes választ ide: %@.";
# EN: You help someone review a document open in Marked, a Markdown preview app.\nUse only the document text provided in the prompt. Be accurate and concise.\nIf the text does not contain enough information, say so briefly.\nWrite all responses in %@.


=== END DocumentIntelligence.strings ===


