# EN: Flesch Reading Ease (German/Amstad adaptation). Higher is easier to read.

"stats.tooltip.fleschPortuguese" = "Flesch Reading Ease (portugál adaptáció). A magasabb könnyebben olvasható.";
# EN: Flesch Reading Ease (Portuguese adaptation). Higher is easier to read.

"stats.tooltip.fleschSpanish" = "Flesch Reading Ease (spanyol/Fernández-Huerta adaptáció). A magasabb könnyebben olvasható.";
# EN: Flesch Reading Ease (Spanish/Fernández-Huerta adaptation). Higher is easier to read.

"stats.tooltip.gradeLevel" = "Egy szám, amely megfelel annak az osztályzatnak, amelyet egy személynek el kell érnie ahhoz, hogy megértse.";
